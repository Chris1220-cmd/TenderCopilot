# Database
DATABASE_URL="postgresql://tender:tender@localhost:5432/tendercopilot?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# S3 / MinIO
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="tendercopilot"
S3_REGION="us-east-1"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# AI Provider (claude, openai, or mock)
AI_PROVIDER="mock"
AI_API_KEY=""

# Email (optional - uses console transport by default)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@tendercopilot.gr"
