generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── Multi-tenant ───────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  countries String[] @default(["GR"])
  language  String   @default("el")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          TenantUser[]
  companyProfiles CompanyProfile[]
  certificates   Certificate[]
  legalDocs      LegalDocument[]
  projects       Project[]
  contentLibrary ContentLibraryItem[]
  tenders              Tender[]
  invitations          Invitation[]
  financialProfiles    FinancialProfile[]
  privateTenderSources PrivateTenderSource[]

  // Smart AI Assistant
  documentChunks   DocumentChunk[]
  chatMessages     ChatMessage[]
  tenderAlerts     TenderAlert[]

  // Learning Memory
  memories         TenantMemory[]

  // Smart Chat Memory
  chatSessions     ChatSession[]

  // Deadline Planner
  deadlinePlanItems DeadlinePlanItem[]

  // CV Database
  teamMembers    TeamMember[]

  // Guarantee Letters
  guaranteeLetters GuaranteeLetter[]

  // Subscription & Usage
  subscription     Subscription?
  usageRecords     UsageRecord[]
  loginEvents      LoginEvent[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String?
  image          String?
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenants       TenantUser[]
  accounts      Account[]
  sessions      Session[]
  assignedTasks Task[]        @relation("TaskAssignee")
  createdTasks  Task[]        @relation("TaskCreator")
  activities    Activity[]
  isSuperAdmin  Boolean  @default(false)
  loginEvents   LoginEvent[]
}

model TenantUser {
  id       String     @id @default(cuid())
  role     TenantRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

enum TenantRole {
  ADMIN
  MEMBER
  EXTERNAL_COLLABORATOR
}

model Invitation {
  id        String         @id @default(cuid())
  email     String
  role      TenantRole     @default(MEMBER)
  status    InviteStatus   @default(PENDING)
  token     String         @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime       @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── NextAuth models ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Company Profile & Master Library ───────────────────────

model CompanyProfile {
  id                  String  @id @default(cuid())
  legalName           String
  tradeName           String?
  taxId               String  // ΑΦΜ
  taxOffice           String? // ΔΟΥ
  registrationNumber  String? // ΓΕΜΗ
  address             String?
  city                String?
  postalCode          String?
  country             String  @default("GR")
  phone               String?
  email               String?
  website             String?
  legalRepName        String? // Νόμιμος Εκπρόσωπος
  legalRepTitle       String?
  legalRepIdNumber    String?
  kadCodes            String[] // ΚΑΔ codes array
  description         String?  @db.Text
  guaranteeCreditLine Float?   // Total credit line for guarantee letters (EUR)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, country])
}

model Certificate {
  id          String    @id @default(cuid())
  type        String    // ISO 9001, ISO 14001, etc.
  title       String
  issuer      String?
  issueDate   DateTime?
  expiryDate  DateTime?
  fileKey     String?   // S3 key
  fileName    String?
  notes       String?   @db.Text

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirementMappings RequirementMapping[]
  deadlinePlanItems   DeadlinePlanItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalDocument {
  id          String           @id @default(cuid())
  type        String
  title       String
  issueDate   DateTime?
  expiryDate  DateTime?
  fileKey     String?
  fileName    String?
  notes       String?          @db.Text

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirementMappings RequirementMapping[]
  deadlinePlanItems   DeadlinePlanItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model Project {
  id              String    @id @default(cuid())
  title           String
  description     String?   @db.Text
  client          String?
  contractAmount  Float?
  startDate       DateTime?
  endDate         DateTime?
  category        String?
  proofFileKey    String?   // S3 key for certificate of completion etc.
  proofFileName   String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirementMappings RequirementMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentLibraryItem {
  id       String             @id @default(cuid())
  category ContentCategory
  title    String
  content  String             @db.Text
  tags     String[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirementMappings RequirementMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ContentCategory {
  COMPANY_PROFILE
  METHODOLOGY
  QA_PLAN
  HSE_PLAN
  TEAM_DESCRIPTION
  RISK_MANAGEMENT
  OTHER
}

// ─── Tender ─────────────────────────────────────────────────

model Tender {
  id                   String        @id @default(cuid())
  title                String
  referenceNumber      String?
  contractingAuthority String?
  platform             TenderPlatform @default(OTHER)
  cpvCodes             String[]
  budget               Float?
  awardCriteria        String?       @db.Text
  submissionDeadline   DateTime?
  status               TenderStatus  @default(DISCOVERY)
  complianceScore      Float?        // 0-100
  notes                String?       @db.Text
  analysisInProgress   Boolean       @default(false)
  country              String        @default("GR")

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirements       TenderRequirement[]
  attachedDocuments  AttachedDocument[]
  generatedDocuments GeneratedDocument[]
  tasks              Task[]
  activities         Activity[]

  // AI Role models
  brief              TenderBrief?
  goNoGoDecision     GoNoGoDecision?
  legalClauses       LegalClause[]
  clarifications     ClarificationQuestion[]
  pricingScenarios   PricingScenario[]
  technicalSections  TechnicalProposalSection[]
  technicalRisks     TechnicalRisk[]
  teamRequirements   TeamRequirement[]
  subcontractorNeeds SubcontractorNeed[]

  analysisLanguage  String  @default("el")

  // Fakelos Checker
  fakelosReport     Json?
  fakelosCheckedAt  DateTime?

  // Smart AI Assistant
  documentChunks   DocumentChunk[]
  chatMessages     ChatMessage[]
  alerts           TenderAlert[]

  // Learning Memory
  outcome          TenderOutcome?

  // Smart Chat Memory
  chatSessions     ChatSession[]

  // Deadline Planner
  deadlinePlanItems DeadlinePlanItem[]

  // Clarification Monitoring
  lastClarificationCheckAt DateTime?

  // ESPD Auto-Generator
  espdData Json?

  // Evaluation Criteria Writing Assistant
  evaluationCriteria EvaluationCriterion[]

  // Tender Intelligence
  intelligence TenderIntelligence?

  // Smart Document Assembly
  packageSubmissions PackageSubmission[]

  // Guarantee Letters
  guaranteeLetters GuaranteeLetter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

enum TenderPlatform {
  ESIDIS
  COSMOONE
  ISUPPLIES
  DIAVGEIA
  TED
  KIMDIS
  OTHER
  PRIVATE
  GOOGLE
  EU_MEMBER
}

enum TenderStatus {
  DISCOVERY
  GO_NO_GO
  IN_PROGRESS
  SUBMITTED
  WON
  LOST
}

model PrivateTenderSource {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  url       String
  country   String   @default("GR")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenderRequirement {
  id               String              @id @default(cuid())
  text             String              @db.Text
  category         RequirementCategory
  articleReference String?
  mandatory        Boolean             @default(true)
  type             RequirementType     @default(DOCUMENT)
  coverageStatus   CoverageStatus      @default(UNMAPPED)
  aiConfidence     Float?              // 0-1 confidence from AI extraction
  criticality      Int?                // 1-5 importance score
  evidenceRefs     Json?               // [{ docId, page, paragraph }]
  notes            String?             @db.Text

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  mappings          RequirementMapping[]
  tasks             Task[]
  deadlinePlanItems DeadlinePlanItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RequirementCategory {
  PARTICIPATION_CRITERIA
  EXCLUSION_CRITERIA
  TECHNICAL_REQUIREMENTS
  FINANCIAL_REQUIREMENTS
  DOCUMENTATION_REQUIREMENTS
  CONTRACT_TERMS
}

enum RequirementType {
  DOCUMENT
  EXPERIENCE
  CERTIFICATE
  DECLARATION
  FINANCIAL
  TECHNICAL
  OTHER
}

enum CoverageStatus {
  UNMAPPED
  COVERED
  GAP
  IN_PROGRESS
  MANUAL_OVERRIDE
}

model RequirementMapping {
  id String @id @default(cuid())

  requirementId String
  requirement   TenderRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  // Polymorphic mapping - one of these will be set
  certificateId      String?
  certificate        Certificate?      @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  legalDocumentId    String?
  legalDocument      LegalDocument?    @relation(fields: [legalDocumentId], references: [id], onDelete: SetNull)
  projectId          String?
  project            Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contentLibraryItemId String?
  contentLibraryItem ContentLibraryItem? @relation(fields: [contentLibraryItemId], references: [id], onDelete: SetNull)

  notes String? @db.Text

  createdAt DateTime @default(now())
}

// ─── Documents ──────────────────────────────────────────────

model AttachedDocument {
  id            String  @id @default(cuid())
  fileName      String
  fileKey       String  // S3 key
  fileSize      Int?
  mimeType      String?
  category      String? // e.g. "specification", "appendix", "clarification"
  extractedText String? @db.Text
  pageCount     Int?
  parsingStatus String? // 'success' | 'partial' | 'failed'
  parsingError  String?

  // Extraction pipeline metadata
  extractionMethod     String?  // 'pdf_parse' | 'document_ai' | 'gemini_vision'
  extractionConfidence Float?   // 0.0 - 1.0
  docAiRecommended     Boolean  @default(false)
  qualityGateResult    String?  @db.Text // JSON: { charsPerKB, keywordHits, charsPerPage, passed, reasons }

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  chunks DocumentChunk[]

  @@index([tenderId])
}

model DocumentChunk {
  id          String   @id @default(cuid())
  documentId  String
  document    AttachedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tenderId    String
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  chunkIndex  Int
  content     String   @db.Text
  embedding   Unsupported("vector(768)")?
  metadata    Json?
  tokenCount  Int

  createdAt   DateTime @default(now())

  @@index([tenderId, tenantId])
  @@index([documentId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  tenderId  String
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  role      String
  content   String   @db.Text
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([tenderId, tenantId, createdAt])
}

model ChatSession {
  id                 String    @id @default(cuid())
  tenderId           String
  tender             Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  summary            String?   @db.Text
  lastSummarizedAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([tenderId, tenantId])
  @@index([tenantId])
}

model TenderAlert {
  id        String   @id @default(cuid())
  tenderId  String
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  type      String
  severity  String
  title     String
  detail    String   @db.Text
  source    String?

  dismissed  Boolean  @default(false)
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([tenderId, tenantId, dismissed])
}

model GeneratedDocument {
  id       String          @id @default(cuid())
  type     GeneratedDocType
  title    String
  content  String          @db.Text // JSON or markdown content
  fileKey  String?         // S3 key for generated file
  fileName String?
  status   DocGenStatus    @default(DRAFT)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GeneratedDocType {
  SOLEMN_DECLARATION        // Υπεύθυνη δήλωση
  NON_EXCLUSION_DECLARATION // Δήλωση μη αποκλεισμού
  TECHNICAL_COMPLIANCE      // Πίνακας τεχνικής συμμόρφωσης
  TECHNICAL_PROPOSAL        // Τεχνική προσφορά
  METHODOLOGY               // Μεθοδολογία
  COVER_LETTER              // Συνοδευτική επιστολή
  OTHER
  ESPD
  COMPANY_EXPERIENCE_TABLE  // Πίνακας εμπειρίας εταιρείας
}

enum DocGenStatus {
  DRAFT
  REVIEWED
  FINAL
}

// ─── Tasks ──────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  assigneeRole String?    // "legal", "financial", "technical", "compliance", "admin"
  isAiGenerated Boolean   @default(false)

  tenderId    String
  tender      Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  assigneeId  String?
  assignee    User?  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId   String?
  creator     User?  @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  requirementId String?
  requirement   TenderRequirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  deadlinePlanItems DeadlinePlanItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── AI Bid Orchestrator ────────────────────────────────────

model TenderBrief {
  id          String @id @default(cuid())
  summaryText String @db.Text
  keyPoints   Json   // { sector, mandatoryCriteria[], awardType, duration, deadlines[] }
  sector      String?
  awardType   String? // "lowest_price" | "best_value"
  duration    String?

  tenderId String @unique
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GoNoGoDecision {
  id             String       @id @default(cuid())
  decision       GoNoGoResult
  overallScore   Float?       // 0-100
  reasons        Json         // [{ factor, score, weight, explanation }]
  recommendation String?      @db.Text
  createdBy      String       @default("AI") // "AI" or userId
  approvedById   String?
  approvedAt     DateTime?

  tenderId String @unique
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GoNoGoResult {
  GO
  NO_GO
  BORDERLINE
}

// ─── AI Legal Analyzer ──────────────────────────────────────

model LegalClause {
  id              String            @id @default(cuid())
  clauseText      String            @db.Text
  category        LegalClauseCategory
  articleRef      String?
  pageNumber      Int?
  riskLevel       RiskLevel         @default(LOW)
  riskReason      String?           @db.Text
  recommendation  String?           @db.Text

  tenderId        String
  tender          Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  sourceDocumentId String?

  clarifications ClarificationQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riskLevel])
}

enum LegalClauseCategory {
  LIABILITY
  TERMINATION
  IP_RIGHTS
  CONFIDENTIALITY
  PENALTIES
  INSURANCE
  DATA_PROTECTION
  GUARANTEES
  SUBCONTRACTING
  FORCE_MAJEURE
  PAYMENT_TERMS
  DISPUTE_RESOLUTION
  OTHER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ClarificationQuestion {
  id           String              @id @default(cuid())
  questionText String              @db.Text
  answerText   String?             @db.Text
  status       ClarificationStatus @default(DRAFT)
  priority     Int                 @default(0)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  clauseId String?
  clause   LegalClause? @relation(fields: [clauseId], references: [id], onDelete: SetNull)

  // Clarification Monitoring (Feature 3)
  source      String    @default("AI_GENERATED") // "AI_GENERATED" | "AUTHORITY_PUBLISHED"
  publishedAt DateTime?
  sourceUrl   String?
  isRead      Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ClarificationStatus {
  DRAFT
  APPROVED
  SENT
  ANSWERED
}

// ─── AI Financial Modeller ──────────────────────────────────

model FinancialProfile {
  id          String @id @default(cuid())
  year        Int
  turnover    Float?
  ebitda      Float?
  equity      Float?
  debt        Float?
  employees   Int?
  bankRating  String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, year])
}

model PricingScenario {
  id         String @id @default(cuid())
  name       String
  baseCosts  Json   // { labor, materials, subcontracting, overhead, other }
  margin     Float  // percentage
  totalPrice Float
  winProbability Float? // 0-100 AI-estimated
  comments   String? @db.Text
  isSelected Boolean @default(false)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── AI Technical Engine ────────────────────────────────────

model TechnicalProposalSection {
  id       String              @id @default(cuid())
  title    String
  ordering Int                 @default(0)
  content  String              @db.Text // markdown
  status   ProposalSectionStatus @default(AI_DRAFT)
  aiNotes  String?             @db.Text

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProposalSectionStatus {
  AI_DRAFT
  HUMAN_EDITING
  REVIEWED
  APPROVED
}

model TechnicalRisk {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  riskLevel   RiskLevel @default(MEDIUM)
  mitigation  String?   @db.Text
  relatedRequirementId String?

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── AI Team/Resource Planning ──────────────────────────────

model TeamRequirement {
  id             String @id @default(cuid())
  role           String // "Project Manager", "Senior Developer", etc.
  qualifications String? @db.Text // required degrees, certifications
  minExperience  Int?    // years
  count          Int     @default(1)
  isMandatory    Boolean @default(true)
  mappedStaffName String? // which company person fills this
  cvFileKey      String?
  status         CoverageStatus @default(UNMAPPED)

  assignedMemberId String?
  assignedMember   TeamMember? @relation("AssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CV Database ─────────────────────────────────────────────

model TeamMember {
  id              String   @id @default(cuid())
  fullName        String
  title           String
  email           String?
  phone           String?
  totalExperience Int      @default(0)
  bio             String?  @db.Text
  cvFileKey       String?
  cvFileName      String?
  isActive        Boolean  @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  education      TeamMemberEducation[]
  experience     TeamMemberExperience[]
  certifications TeamMemberCertification[]
  assignments    TeamRequirement[]         @relation("AssignedMember")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model TeamMemberEducation {
  id          String @id @default(cuid())
  degree      String
  institution String
  year        Int?

  memberId String
  member   TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model TeamMemberExperience {
  id          String   @id @default(cuid())
  projectName String
  client      String
  role        String
  budget      Decimal? @db.Decimal(14, 2)
  startYear   Int
  endYear     Int?
  description String?  @db.Text
  category    String?

  memberId String
  member   TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model TeamMemberCertification {
  id         String    @id @default(cuid())
  name       String
  issuer     String
  issueDate  DateTime?
  expiryDate DateTime?

  memberId String
  member   TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ─── Subcontractor & Supplier Needs ─────────────────────────

enum SubcontractorKind {
  SUBCONTRACTOR
  SUPPLIER
}

enum SubcontractorStatus {
  PENDING
  IN_PROGRESS
  COVERED
}

model SubcontractorNeed {
  id             String              @id @default(cuid())
  specialty      String              // "Υδραυλικός", "Ηλεκτρολόγος"
  kind           SubcontractorKind   // SUBCONTRACTOR | SUPPLIER
  reason         String   @db.Text   // "Απαιτείται από Άρθρο 3.2 — εγκατάσταση υδραυλικών"
  isMandatory    Boolean  @default(false)
  requiredCerts  Json     @default("[]") // ["Άδεια ΥΔΕ", "ISO 14001"]
  guidance       String?  @db.Text   // AI-generated advice
  status         SubcontractorStatus @default(PENDING)
  assignedName   String?             // "Παπαδόπουλος Ηλεκτρικά"
  notes          String?  @db.Text
  isAiGenerated  Boolean  @default(true)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenderId])
}

// ─── Evaluation Criteria Writing Assistant ──────────────────

enum CriterionStatus {
  NOT_STARTED
  IN_PROGRESS
  DRAFT_READY
  FINAL
}

model EvaluationCriterion {
  id          String   @id @default(cuid())
  tenderId    String
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  name        String
  weight      Float?
  parentId    String?
  parent      EvaluationCriterion?    @relation("CriteriaTree", fields: [parentId], references: [id])
  children    EvaluationCriterion[]   @relation("CriteriaTree")
  sortOrder   Int       @default(0)

  description String?   @db.Text
  guidance    String?   @db.Text
  evidence    String?   @db.Text
  suggestions String?   @db.Text

  status      CriterionStatus @default(NOT_STARTED)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenderId])
  @@index([parentId])
}

// ─── Tender Intelligence ────────────────────────────────────

model TenderIntelligence {
  id        String   @id @default(cuid())
  tenderId  String   @unique
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  similarAwards    Json?
  competitors      Json?
  authorityProfile Json?
  repeatTender     Json?
  prepTimeEstimate Json?
  aiAdvisory       Json?

  language   String    @default("el")
  fetchedAt  DateTime  @default(now())

  @@index([tenderId])
}

// ─── Smart Document Assembly ────────────────────────────────

model PackageSubmission {
  id        String   @id @default(cuid())
  tenderId  String
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  documentCount  Int
  envelopeCount  Int
  fileSize       Int?
  blockerCount   Int
  warningCount   Int

  manifest  Json

  createdAt DateTime @default(now())
  createdBy String?

  @@index([tenderId])
}

// ─── Activity Log ───────────────────────────────────────────

model Activity {
  id      String @id @default(cuid())
  action  String
  details String? @db.Text

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

// ─── Learning Memory ─────────────────────────────────────────

model TenantMemory {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   String   // 'strength' | 'weakness' | 'preference' | 'pattern' | 'lesson'
  key        String   // e.g. 'has_iso_9001', 'weak_in_software', 'prefers_conservative_pricing'
  value      String   @db.Text  // description
  confidence Float    @default(0.5) // 0-1, increases with more evidence
  evidence   Json?    // array of {tenderId, date, detail}
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, category, key])
  @@index([tenantId])
}

model TenderOutcome {
  id        String   @id @default(cuid())
  tenderId  String   @unique
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId  String
  outcome   String   // 'won' | 'lost' | 'withdrew' | 'disqualified'
  reason    String?  @db.Text  // why won/lost
  bidAmount Float?
  winAmount Float?   // winning bid if lost
  lessons   Json?    // AI-extracted lessons
  feedback  String?  @db.Text  // user notes
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model ChatFeedback {
  id        String   @id @default(cuid())
  messageId String   @unique
  tenantId  String
  rating    Int      // 1 (bad) or 5 (good) — thumbs down/up
  comment   String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ─── Deadline Planner ──────────────────────────────────────

model DeadlinePlanItem {
  id                String              @id @default(cuid())
  tenderId          String
  tenantId          String

  documentType      String
  title             String
  description       String?
  envelope          String?

  leadTimeDays      Int
  validityDays      Int?
  latestStartDate   DateTime
  optimalStartDate  DateTime?
  dueDate           DateTime

  status            String              @default("PENDING")
  obtainedAt        DateTime?
  source            String?
  isMandatory       Boolean             @default(true)
  isAiGenerated     Boolean             @default(false)

  tender            Tender              @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  requirement       TenderRequirement?  @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  linkedTask        Task?               @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)
  certificate       Certificate?        @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  legalDoc          LegalDocument?      @relation(fields: [legalDocId], references: [id], onDelete: SetNull)

  requirementId     String?
  linkedTaskId      String?
  certificateId     String?
  legalDocId        String?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([tenderId, tenantId])
  @@index([tenantId, status])
  @@index([dueDate])
}

// ─── Guarantee Letters ───────────────────────────────────────

enum GuaranteeType {
  PARTICIPATION    // Εγγυητική Συμμετοχής (2%)
  PERFORMANCE      // Εγγυητική Καλής Εκτέλεσης (4%)
  ADVANCE_PAYMENT  // Εγγυητική Προκαταβολής
}

enum GuaranteeStatus {
  REQUESTED
  ISSUED
  ACTIVE
  RELEASED
  EXPIRED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

model GuaranteeLetter {
  id              String          @id @default(cuid())
  tenderId        String
  tenantId        String
  type            GuaranteeType   @default(PARTICIPATION)
  amount          Float
  bank            String?
  referenceNumber String?
  status          GuaranteeStatus @default(REQUESTED)
  requestedAt     DateTime?
  issuedAt        DateTime?
  validUntil      DateTime?
  releasedAt      DateTime?
  notes           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenderId])
}

// ─── Subscription Plans & Usage ─────────────────────────────

model Plan {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  price          Float
  priceAnnual    Float

  maxActiveTenders      Int?
  maxAiCreditsPerMonth  Int?
  maxDocumentsPerMonth  Int?
  maxSearchesPerMonth   Int?
  maxStorageMB          Int?
  maxUsers              Int?
  maxCountries          Int?

  features       Json     @default("{}")
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  trialDays      Int      @default(14)

  subscriptions  Subscription[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Subscription {
  id                    String             @id @default(cuid())
  status                SubscriptionStatus @default(TRIAL)
  billingCycle          BillingCycle       @default(MONTHLY)
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  trialEndsAt           DateTime?
  cancelledAt           DateTime?

  stripeSubscriptionId  String?
  stripeCustomerId      String?

  tenantId              String             @unique
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planId                String
  plan                  Plan               @relation(fields: [planId], references: [id])

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model UsageRecord {
  id                  String   @id @default(cuid())
  period              String
  activeTenders       Int      @default(0)
  aiCreditsUsed       Int      @default(0)
  documentsGenerated  Int      @default(0)
  searchesPerformed   Int      @default(0)
  storageUsedMB       Float    @default(0)

  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId])
}

model LoginEvent {
  id          String   @id @default(cuid())
  ipAddress   String?
  userAgent   String?
  deviceType  String?
  geoCity     String?
  geoCountry  String?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}
