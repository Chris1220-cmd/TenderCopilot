generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── Multi-tenant ───────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          TenantUser[]
  companyProfile CompanyProfile?
  certificates   Certificate[]
  legalDocs      LegalDocument[]
  projects       Project[]
  contentLibrary ContentLibraryItem[]
  tenders              Tender[]
  invitations          Invitation[]
  financialProfiles    FinancialProfile[]
  privateTenderSources PrivateTenderSource[]

  // Smart AI Assistant
  documentChunks   DocumentChunk[]
  chatMessages     ChatMessage[]
  tenderAlerts     TenderAlert[]

  // Learning Memory
  memories         TenantMemory[]

  // Smart Chat Memory
  chatSessions     ChatSession[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String?
  image          String?
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenants       TenantUser[]
  accounts      Account[]
  sessions      Session[]
  assignedTasks Task[]        @relation("TaskAssignee")
  createdTasks  Task[]        @relation("TaskCreator")
  activities    Activity[]
}

model TenantUser {
  id       String     @id @default(cuid())
  role     TenantRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

enum TenantRole {
  ADMIN
  MEMBER
  EXTERNAL_COLLABORATOR
}

model Invitation {
  id        String         @id @default(cuid())
  email     String
  role      TenantRole     @default(MEMBER)
  status    InviteStatus   @default(PENDING)
  token     String         @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime       @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── NextAuth models ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Company Profile & Master Library ───────────────────────

model CompanyProfile {
  id                  String  @id @default(cuid())
  legalName           String
  tradeName           String?
  taxId               String  // ΑΦΜ
  taxOffice           String? // ΔΟΥ
  registrationNumber  String? // ΓΕΜΗ
  address             String?
  city                String?
  postalCode          String?
  country             String  @default("GR")
  phone               String?
  email               String?
  website             String?
  legalRepName        String? // Νόμιμος Εκπρόσωπος
  legalRepTitle       String?
  legalRepIdNumber    String?
  kadCodes            String[] // ΚΑΔ codes array
  description         String?  @db.Text

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Certificate {
  id          String    @id @default(cuid())
  type        String    // ISO 9001, ISO 14001, etc.
  title       String
  issuer      String?
  issueDate   DateTime?
  expiryDate  DateTime?
  fileKey     String?   // S3 key
  fileName    String?
  notes       String?   @db.Text

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirementMappings RequirementMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalDocument {
  id          String           @id @default(cuid())
  type        LegalDocType
  title       String
  issueDate   DateTime?
  expiryDate  DateTime?
  fileKey     String?
  fileName    String?
  notes       String?          @db.Text

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirementMappings RequirementMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LegalDocType {
  TAX_CLEARANCE           // Φορολογική ενημερότητα
  SOCIAL_SECURITY_CLEARANCE // Ασφαλιστική ενημερότητα
  GEMI_CERTIFICATE        // ΓΕΜΗ
  CRIMINAL_RECORD         // Ποινικό μητρώο
  JUDICIAL_CERTIFICATE    // Δικαστικό πιστοποιητικό
  OTHER
}

model Project {
  id              String    @id @default(cuid())
  title           String
  description     String?   @db.Text
  client          String?
  contractAmount  Float?
  startDate       DateTime?
  endDate         DateTime?
  category        String?
  proofFileKey    String?   // S3 key for certificate of completion etc.
  proofFileName   String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirementMappings RequirementMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentLibraryItem {
  id       String             @id @default(cuid())
  category ContentCategory
  title    String
  content  String             @db.Text
  tags     String[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirementMappings RequirementMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ContentCategory {
  COMPANY_PROFILE
  METHODOLOGY
  QA_PLAN
  HSE_PLAN
  TEAM_DESCRIPTION
  RISK_MANAGEMENT
  OTHER
}

// ─── Tender ─────────────────────────────────────────────────

model Tender {
  id                   String        @id @default(cuid())
  title                String
  referenceNumber      String?
  contractingAuthority String?
  platform             TenderPlatform @default(OTHER)
  cpvCodes             String[]
  budget               Float?
  awardCriteria        String?       @db.Text
  submissionDeadline   DateTime?
  status               TenderStatus  @default(DISCOVERY)
  complianceScore      Float?        // 0-100
  notes                String?       @db.Text
  analysisInProgress   Boolean       @default(false)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requirements       TenderRequirement[]
  attachedDocuments  AttachedDocument[]
  generatedDocuments GeneratedDocument[]
  tasks              Task[]
  activities         Activity[]

  // AI Role models
  brief              TenderBrief?
  goNoGoDecision     GoNoGoDecision?
  legalClauses       LegalClause[]
  clarifications     ClarificationQuestion[]
  pricingScenarios   PricingScenario[]
  technicalSections  TechnicalProposalSection[]
  technicalRisks     TechnicalRisk[]
  teamRequirements   TeamRequirement[]
  subcontractorNeeds SubcontractorNeed[]

  analysisLanguage  String  @default("el")

  // Fakelos Checker
  fakelosReport     Json?
  fakelosCheckedAt  DateTime?

  // Smart AI Assistant
  documentChunks   DocumentChunk[]
  chatMessages     ChatMessage[]
  alerts           TenderAlert[]

  // Learning Memory
  outcome          TenderOutcome?

  // Smart Chat Memory
  chatSessions     ChatSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

enum TenderPlatform {
  ESIDIS
  COSMOONE
  ISUPPLIES
  DIAVGEIA
  TED
  KIMDIS
  OTHER
  PRIVATE
  GOOGLE
  EU_MEMBER
}

enum TenderStatus {
  DISCOVERY
  GO_NO_GO
  IN_PROGRESS
  SUBMITTED
  WON
  LOST
}

model PrivateTenderSource {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  url       String
  country   String   @default("GR")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenderRequirement {
  id               String              @id @default(cuid())
  text             String              @db.Text
  category         RequirementCategory
  articleReference String?
  mandatory        Boolean             @default(true)
  type             RequirementType     @default(DOCUMENT)
  coverageStatus   CoverageStatus      @default(UNMAPPED)
  aiConfidence     Float?              // 0-1 confidence from AI extraction
  criticality      Int?                // 1-5 importance score
  evidenceRefs     Json?               // [{ docId, page, paragraph }]
  notes            String?             @db.Text

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  mappings RequirementMapping[]
  tasks    Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RequirementCategory {
  PARTICIPATION_CRITERIA
  EXCLUSION_CRITERIA
  TECHNICAL_REQUIREMENTS
  FINANCIAL_REQUIREMENTS
  DOCUMENTATION_REQUIREMENTS
  CONTRACT_TERMS
}

enum RequirementType {
  DOCUMENT
  EXPERIENCE
  CERTIFICATE
  DECLARATION
  FINANCIAL
  TECHNICAL
  OTHER
}

enum CoverageStatus {
  UNMAPPED
  COVERED
  GAP
  IN_PROGRESS
  MANUAL_OVERRIDE
}

model RequirementMapping {
  id String @id @default(cuid())

  requirementId String
  requirement   TenderRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  // Polymorphic mapping - one of these will be set
  certificateId      String?
  certificate        Certificate?      @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  legalDocumentId    String?
  legalDocument      LegalDocument?    @relation(fields: [legalDocumentId], references: [id], onDelete: SetNull)
  projectId          String?
  project            Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contentLibraryItemId String?
  contentLibraryItem ContentLibraryItem? @relation(fields: [contentLibraryItemId], references: [id], onDelete: SetNull)

  notes String? @db.Text

  createdAt DateTime @default(now())
}

// ─── Documents ──────────────────────────────────────────────

model AttachedDocument {
  id            String  @id @default(cuid())
  fileName      String
  fileKey       String  // S3 key
  fileSize      Int?
  mimeType      String?
  category      String? // e.g. "specification", "appendix", "clarification"
  extractedText String? @db.Text
  pageCount     Int?
  parsingStatus String? // 'success' | 'partial' | 'failed'
  parsingError  String?

  // Extraction pipeline metadata
  extractionMethod     String?  // 'pdf_parse' | 'document_ai' | 'gemini_vision'
  extractionConfidence Float?   // 0.0 - 1.0
  docAiRecommended     Boolean  @default(false)
  qualityGateResult    String?  @db.Text // JSON: { charsPerKB, keywordHits, charsPerPage, passed, reasons }

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  chunks DocumentChunk[]

  @@index([tenderId])
}

model DocumentChunk {
  id          String   @id @default(cuid())
  documentId  String
  document    AttachedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tenderId    String
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  chunkIndex  Int
  content     String   @db.Text
  embedding   Unsupported("vector(768)")?
  metadata    Json?
  tokenCount  Int

  createdAt   DateTime @default(now())

  @@index([tenderId, tenantId])
  @@index([documentId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  tenderId  String
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  role      String
  content   String   @db.Text
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([tenderId, tenantId, createdAt])
}

model ChatSession {
  id                 String    @id @default(cuid())
  tenderId           String
  tender             Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  summary            String?   @db.Text
  lastSummarizedAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([tenderId, tenantId])
  @@index([tenantId])
}

model TenderAlert {
  id        String   @id @default(cuid())
  tenderId  String
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  type      String
  severity  String
  title     String
  detail    String   @db.Text
  source    String?

  dismissed  Boolean  @default(false)
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([tenderId, tenantId, dismissed])
}

model GeneratedDocument {
  id       String          @id @default(cuid())
  type     GeneratedDocType
  title    String
  content  String          @db.Text // JSON or markdown content
  fileKey  String?         // S3 key for generated file
  fileName String?
  status   DocGenStatus    @default(DRAFT)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GeneratedDocType {
  SOLEMN_DECLARATION        // Υπεύθυνη δήλωση
  NON_EXCLUSION_DECLARATION // Δήλωση μη αποκλεισμού
  TECHNICAL_COMPLIANCE      // Πίνακας τεχνικής συμμόρφωσης
  TECHNICAL_PROPOSAL        // Τεχνική προσφορά
  METHODOLOGY               // Μεθοδολογία
  COVER_LETTER              // Συνοδευτική επιστολή
  OTHER
}

enum DocGenStatus {
  DRAFT
  REVIEWED
  FINAL
}

// ─── Tasks ──────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  assigneeRole String?    // "legal", "financial", "technical", "compliance", "admin"
  isAiGenerated Boolean   @default(false)

  tenderId    String
  tender      Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  assigneeId  String?
  assignee    User?  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId   String?
  creator     User?  @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  requirementId String?
  requirement   TenderRequirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── AI Bid Orchestrator ────────────────────────────────────

model TenderBrief {
  id          String @id @default(cuid())
  summaryText String @db.Text
  keyPoints   Json   // { sector, mandatoryCriteria[], awardType, duration, deadlines[] }
  sector      String?
  awardType   String? // "lowest_price" | "best_value"
  duration    String?

  tenderId String @unique
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GoNoGoDecision {
  id             String       @id @default(cuid())
  decision       GoNoGoResult
  overallScore   Float?       // 0-100
  reasons        Json         // [{ factor, score, weight, explanation }]
  recommendation String?      @db.Text
  createdBy      String       @default("AI") // "AI" or userId
  approvedById   String?
  approvedAt     DateTime?

  tenderId String @unique
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GoNoGoResult {
  GO
  NO_GO
  BORDERLINE
}

// ─── AI Legal Analyzer ──────────────────────────────────────

model LegalClause {
  id              String            @id @default(cuid())
  clauseText      String            @db.Text
  category        LegalClauseCategory
  articleRef      String?
  pageNumber      Int?
  riskLevel       RiskLevel         @default(LOW)
  riskReason      String?           @db.Text
  recommendation  String?           @db.Text

  tenderId        String
  tender          Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  sourceDocumentId String?

  clarifications ClarificationQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riskLevel])
}

enum LegalClauseCategory {
  LIABILITY
  TERMINATION
  IP_RIGHTS
  CONFIDENTIALITY
  PENALTIES
  INSURANCE
  DATA_PROTECTION
  GUARANTEES
  SUBCONTRACTING
  FORCE_MAJEURE
  PAYMENT_TERMS
  DISPUTE_RESOLUTION
  OTHER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ClarificationQuestion {
  id           String              @id @default(cuid())
  questionText String              @db.Text
  answerText   String?             @db.Text
  status       ClarificationStatus @default(DRAFT)
  priority     Int                 @default(0)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  clauseId String?
  clause   LegalClause? @relation(fields: [clauseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ClarificationStatus {
  DRAFT
  APPROVED
  SENT
  ANSWERED
}

// ─── AI Financial Modeller ──────────────────────────────────

model FinancialProfile {
  id          String @id @default(cuid())
  year        Int
  turnover    Float?
  ebitda      Float?
  equity      Float?
  debt        Float?
  employees   Int?
  bankRating  String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, year])
}

model PricingScenario {
  id         String @id @default(cuid())
  name       String
  baseCosts  Json   // { labor, materials, subcontracting, overhead, other }
  margin     Float  // percentage
  totalPrice Float
  winProbability Float? // 0-100 AI-estimated
  comments   String? @db.Text
  isSelected Boolean @default(false)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── AI Technical Engine ────────────────────────────────────

model TechnicalProposalSection {
  id       String              @id @default(cuid())
  title    String
  ordering Int                 @default(0)
  content  String              @db.Text // markdown
  status   ProposalSectionStatus @default(AI_DRAFT)
  aiNotes  String?             @db.Text

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProposalSectionStatus {
  AI_DRAFT
  HUMAN_EDITING
  REVIEWED
  APPROVED
}

model TechnicalRisk {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  riskLevel   RiskLevel @default(MEDIUM)
  mitigation  String?   @db.Text
  relatedRequirementId String?

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── AI Team/Resource Planning ──────────────────────────────

model TeamRequirement {
  id             String @id @default(cuid())
  role           String // "Project Manager", "Senior Developer", etc.
  qualifications String? @db.Text // required degrees, certifications
  minExperience  Int?    // years
  count          Int     @default(1)
  isMandatory    Boolean @default(true)
  mappedStaffName String? // which company person fills this
  cvFileKey      String?
  status         CoverageStatus @default(UNMAPPED)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Subcontractor & Supplier Needs ─────────────────────────

enum SubcontractorKind {
  SUBCONTRACTOR
  SUPPLIER
}

enum SubcontractorStatus {
  PENDING
  IN_PROGRESS
  COVERED
}

model SubcontractorNeed {
  id             String              @id @default(cuid())
  specialty      String              // "Υδραυλικός", "Ηλεκτρολόγος"
  kind           SubcontractorKind   // SUBCONTRACTOR | SUPPLIER
  reason         String   @db.Text   // "Απαιτείται από Άρθρο 3.2 — εγκατάσταση υδραυλικών"
  isMandatory    Boolean  @default(false)
  requiredCerts  Json     @default("[]") // ["Άδεια ΥΔΕ", "ISO 14001"]
  guidance       String?  @db.Text   // AI-generated advice
  status         SubcontractorStatus @default(PENDING)
  assignedName   String?             // "Παπαδόπουλος Ηλεκτρικά"
  notes          String?  @db.Text
  isAiGenerated  Boolean  @default(true)

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenderId])
}

// ─── Activity Log ───────────────────────────────────────────

model Activity {
  id      String @id @default(cuid())
  action  String
  details String? @db.Text

  tenderId String
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

// ─── Learning Memory ─────────────────────────────────────────

model TenantMemory {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   String   // 'strength' | 'weakness' | 'preference' | 'pattern' | 'lesson'
  key        String   // e.g. 'has_iso_9001', 'weak_in_software', 'prefers_conservative_pricing'
  value      String   @db.Text  // description
  confidence Float    @default(0.5) // 0-1, increases with more evidence
  evidence   Json?    // array of {tenderId, date, detail}
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, category, key])
  @@index([tenantId])
}

model TenderOutcome {
  id        String   @id @default(cuid())
  tenderId  String   @unique
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenantId  String
  outcome   String   // 'won' | 'lost' | 'withdrew' | 'disqualified'
  reason    String?  @db.Text  // why won/lost
  bidAmount Float?
  winAmount Float?   // winning bid if lost
  lessons   Json?    // AI-extracted lessons
  feedback  String?  @db.Text  // user notes
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model ChatFeedback {
  id        String   @id @default(cuid())
  messageId String   @unique
  tenantId  String
  rating    Int      // 1 (bad) or 5 (good) — thumbs down/up
  comment   String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}
